{
  "name": "@webacp/react",
  "version": "0.1.2",
  "description": "Headless React hooks and store for WebACP chat apps.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohityadav0903/webAcp.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@webacp/protocol": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "zustand": ">=5"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "react": "^19.0.0",
    "typescript": "^5.8.2",
    "zustand": "^5.0.3"
  }
}
