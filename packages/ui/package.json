{
  "name": "@webacp/ui",
  "version": "0.1.2",
  "description": "Themed WebACP chat UI components (shadcn-compatible CSS variables).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohityadav0903/webAcp.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme/default.css": "./src/theme/default.css",
    "./theme/light.css": "./src/theme/light.css"
  },
  "files": ["dist", "src/theme"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@webacp/protocol": "workspace:*",
    "@webacp/react": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "tailwind-merge": "^3.3.1"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "react": "^19.0.0",
    "typescript": "^5.8.2"
  }
}
