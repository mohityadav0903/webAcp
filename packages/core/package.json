{
  "name": "@webacp/core",
  "version": "0.1.0",
  "description": "ACP engine for WebACP: providers, sessions, prompt adapter.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohityadav0903/webAcp.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
