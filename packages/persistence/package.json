{
  "name": "@webacp/persistence",
  "version": "0.1.2",
  "description": "Thread and message persistence adapters for WebACP (SQLite + in-memory).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohityadav0903/webAcp.git",
    "directory": "packages/persistence"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@webacp/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "typescript": "^5.8.2"
  }
}
