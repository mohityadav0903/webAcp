{
  "name": "@webacp/agent",
  "version": "0.1.2",
  "description": "Local WebACP agent daemon and webacp-agent CLI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohityadav0903/webAcp.git",
    "directory": "packages/agent"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "webacp-agent": "bin/webacp-agent.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@webacp/core": "workspace:*",
    "@webacp/protocol": "workspace:*",
    "@webacp/tools": "workspace:*",
    "@webacp/tools-fs": "workspace:*",
    "cursor-acp-enriched": "^0.4.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "typescript": "^5.8.2"
  }
}
