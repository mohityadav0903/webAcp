{
  "name": "@webacp/local-agent",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "webacp-agent": "./bin/webacp-agent.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --compile --outfile dist/webacp-agent"
  },
  "dependencies": {
    "@webacp/agent": "workspace:*",
    "@webacp/tools-fs": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
